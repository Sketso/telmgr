CRON_TAG = "# telmgr-autobackup"

def cmd_backup_auto_enable(hour=3):
    import subprocess as sp
    tag = CRON_TAG
    cron_line = f"0 {hour} * * * /usr/local/bin/telmgr backup  {tag}"
    result = sp.run(["crontab", "-l"], capture_output=True, text=True)
    existing = result.stdout if result.returncode == 0 else ""
    if tag in existing:
        ok(f"Авто-бэкап уже включён (строка с '{tag}' уже есть)")
        return
    new_cron = existing.rstrip("\n") + "\n" + cron_line + "\n"
    sp.run(["crontab", "-"], input=new_cron, text=True, check=True)
    ok(f"Авто-бэкап включён: ежедневно в {hour:02d}:00")

def cmd_backup_auto_disable():
    import subprocess as sp
    tag = CRON_TAG
    result = sp.run(["crontab", "-l"], capture_output=True, text=True)
    if result.returncode != 0 or tag not in result.stdout:
        warn("Авто-бэкап не был включён")
        return
    new_cron = "\n".join(
        line for line in result.stdout.splitlines() if tag not in line
    ) + "\n"
    sp.run(["crontab", "-"], input=new_cron, text=True, check=True)
    ok("Авто-бэкап отключён")

def cmd_backup_auto_status():
    import subprocess as sp
