#!/usr/bin/env python3

import sys
import os
import json
import re
import subprocess
from datetime import datetime, timedelta
from pathlib import Path

# === Конфиг ===
TELEMT_DIR = os.environ.get("TELEMT_DIR", os.path.join(os.path.expanduser("~"), "telemt"))
TOML_PATH = os.path.join(TELEMT_DIR, "telemt.toml")
META_PATH = os.path.join(TELEMT_DIR, ".telmgr-meta.json")
ADMINS_PATH = os.path.join(TELEMT_DIR, ".telmgr-admins.json")
PUBLIC_HOST = os.environ.get("TELEMT_HOST")
PUBLIC_PORT = os.environ.get("TELEMT_PORT", "2053")


# === Цвета ===
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
RESET = "\033[0m"
BOLD = "\033[1m"

def ok(msg): print(f"{GREEN}✅ {msg}{RESET}")
def err(msg): print(f"{RED}❌ {msg}{RESET}"); sys.exit(1)
def warn(msg): print(f"{YELLOW}⚠️  {msg}{RESET}")
def info(msg): print(f"{CYAN}{msg}{RESET}")

# === Метаданные ===
def load_meta():
    if not Path(META_PATH).exists():
        return {}
    with open(META_PATH) as f:
        return json.load(f)

def save_meta(meta):
    with open(META_PATH, "w") as f:
        json.dump(meta, f, indent=2)

# === TOML хелперы ===
def read_toml():
    with open(TOML_PATH) as f:
        return f.read()

def write_toml(content):
    with open(TOML_PATH, "w") as f:
        f.write(content)

def get_users_from_toml(content):
    users = {}
    in_section = False
    for line in content.splitlines():
        if line.strip() == "[access.users]":
            in_section = True
            continue
        if in_section:
            if line.strip().startswith("["):
                break
            m = re.match(r'^(\w+)\s*=\s*"([0-9a-f]{32})"', line.strip())
            if m:
                users[m.group(1)] = {"secret": m.group(2), "disabled": False}
            m = re.match(r'^#\s*(\w+)\s*=\s*"([0-9a-f]{32})"', line.strip())
            if m:
                users[m.group(1)] = {"secret": m.group(2), "disabled": True}
    return users

def generate_secret():
    return subprocess.check_output(["openssl", "rand", "-hex", "16"]).decode().strip()

def build_link(secret):
    if not PUBLIC_HOST:
        err("Укажи переменную окружения TELEMT_HOST")
    domain_hex = PUBLIC_HOST.encode().hex()
    full_secret = f"ee{secret}{domain_hex}"
    return f"tg://proxy?server={PUBLIC_HOST}&port={PUBLIC_PORT}&secret={full_secret}"

# === Команды ===
def cmd_add(name, days=0):
    if not re.match(r'^\w+$', name):
        err("Имя пользователя может содержать только буквы, цифры и _")

    content = read_toml()
    users = get_users_from_toml(content)

    if name in users:
        err(f"Пользователь '{name}' уже существует")

    secret = generate_secret()

    lines = content.splitlines()
    result = []
    inserted = False
    for line in lines:
        result.append(line)
        if line.strip() == "[access.users]" and not inserted:
            result.append(f'{name} = "{secret}"')
            inserted = True

    if not inserted:
        err("Секция [access.users] не найдена в конфиге")

    write_toml("\n".join(result))

    meta = load_meta()
    expires = None
    if days and int(days) > 0:
        expires = (datetime.now() + timedelta(days=int(days))).strftime("%Y-%m-%d")
    meta[name] = {
        "secret": secret,
        "created": datetime.now().strftime("%Y-%m-%d"),
        "expires": expires,
        "disabled": False
    }
    save_meta(meta)

    if expires:
        add_cron(name, expires)

    ok(f"Пользователь '{name}' добавлен")
    if expires:
        info(f"📅 Истекает: {expires}")
    info(f"🔗 Ссылка: {build_link(secret)}")

def cmd_delete(name):
    content = read_toml()
    users = get_users_from_toml(content)

    if name not in users:
        err(f"Пользователь '{name}' не найден")

    lines = content.splitlines()
    result = [l for l in lines if not re.match(rf'^#?\s*{name}\s*=\s*"[0-9a-f]{{32}}"', l)]
    write_toml("\n".join(result))

    meta = load_meta()
    if name in meta:
        del meta[name]
        save_meta(meta)

    remove_cron(name)
    ok(f"Пользователь '{name}' удалён")

def cmd_disable(name):
    content = read_toml()
    users = get_users_from_toml(content)

    if name not in users:
        err(f"Пользователь '{name}' не найден")
    if users[name]["disabled"]:
        warn(f"Пользователь '{name}' уже отключён")
        return

    new_content = re.sub(
        rf'^({name}\s*=\s*"[0-9a-f]{{32}}")',
        r'# \1',
        content,
        flags=re.MULTILINE
    )
    write_toml(new_content)

    meta = load_meta()
    if name in meta:
        meta[name]["disabled"] = True
        save_meta(meta)

    ok(f"Пользователь '{name}' отключён")

def cmd_enable(name):
    content = read_toml()
    users = get_users_from_toml(content)

    if name not in users:
        err(f"Пользователь '{name}' не найден")
    if not users[name]["disabled"]:
        warn(f"Пользователь '{name}' уже активен")
        return

    new_content = re.sub(
        rf'^#\s*({name}\s*=\s*"[0-9a-f]{{32}}")',
        r'\1',
        content,
        flags=re.MULTILINE
    )
    write_toml(new_content)

    meta = load_meta()
    if name in meta:
        meta[name]["disabled"] = False
        save_meta(meta)

    ok(f"Пользователь '{name}' включён")

def cmd_limit(name, days):
    content = read_toml()
    users = get_users_from_toml(content)

    if name not in users:
        err(f"Пользователь '{name}' не найден")

    meta = load_meta()
    if name not in meta:
        err(f"Метаданные для '{name}' не найдены — используй: telmgr user import {name}")

    days = int(days)
    remove_cron(name)

    if days == 0:
        meta[name]["expires"] = None
        save_meta(meta)
        ok(f"Лимит для '{name}' снят — пользователь теперь бессрочный")
        return

    expires = (datetime.now() + timedelta(days=days)).strftime("%Y-%m-%d")
    meta[name]["expires"] = expires
    save_meta(meta)
    add_cron(name, expires)

    ok(f"Лимит установлен: '{name}' будет отключён {expires}")

def cmd_list():
    content = read_toml()
    users = get_users_from_toml(content)
    meta = load_meta()

    if not users:
        info("Пользователей нет")
        return

    print(f"\n{BOLD}{'Имя':<15} {'Статус':<12} {'Создан':<12} {'Истекает':<12}{RESET}")
    print("─" * 55)

    for name, data in users.items():
        m = meta.get(name, {})
        status = f"{RED}disabled{RESET}" if data["disabled"] else f"{GREEN}active{RESET}"
        created = m.get("created", "—")
        expires = m.get("expires") or "∞"

        if m.get("expires"):
            exp_date = datetime.strptime(m["expires"], "%Y-%m-%d")
            if exp_date < datetime.now() and not data["disabled"]:
                expires = f"{RED}{expires} (просрочен!){RESET}"

        print(f"{name:<15} {status:<20} {created:<12} {expires}")
    print()

def cmd_link(name):
    content = read_toml()
    users = get_users_from_toml(content)

    if name not in users:
        err(f"Пользователь '{name}' не найден")

    secret = users[name]["secret"]
    if users[name]["disabled"]:
        warn(f"Пользователь '{name}' отключён, но ссылка:")

    info(f"🔗 {build_link(secret)}")

def cmd_import(name):
    content = read_toml()
    users = get_users_from_toml(content)

    if name not in users:
        err(f"Пользователь '{name}' не найден в конфиге")

    meta = load_meta()
    if name in meta:
        warn(f"Пользователь '{name}' уже есть в метаданных")
        return

    secret = users[name]["secret"]
    meta[name] = {
        "secret": secret,
        "created": datetime.now().strftime("%Y-%m-%d"),
        "expires": None,
        "disabled": users[name]["disabled"]
    }
    save_meta(meta)
    ok(f"Пользователь '{name}' импортирован из конфига")
    info(f"🔗 {build_link(secret)}")

# === Cron ===
def add_cron(name, expires_date):
    dt = datetime.strptime(expires_date, "%Y-%m-%d")
    cron_line = (
        f"0 12 {dt.day} {dt.month} * "
        f"/usr/local/bin/telmgr user disable {name} "
        f">> /var/log/telmgr.log 2>&1 "
        f"# telmgr:{name}"
    )
    current = subprocess.run(["crontab", "-l"], capture_output=True, text=True).stdout
    lines = [l for l in current.splitlines() if f"# telmgr:{name}" not in l]
    lines.append(cron_line)
    new_cron = "\n".join(lines) + "\n"
    subprocess.run(["crontab", "-"], input=new_cron, text=True)

def remove_cron(name):
    current = subprocess.run(["crontab", "-l"], capture_output=True, text=True).stdout
    lines = [l for l in current.splitlines() if f"# telmgr:{name}" not in l]
    new_cron = "\n".join(lines) + "\n"
    subprocess.run(["crontab", "-"], input=new_cron, text=True)

# === Точка входа ===
def cmd_admin_list():
    if not Path(ADMINS_PATH).exists():
        info("Файл админов не найден")
        return
    with open(ADMINS_PATH) as f:
        data = json.load(f)
    admins = data.get('admins', {})
    pending = data.get('pending', {})

    print(f"\n{BOLD}Админы:{RESET}")
    if not admins:
        print("  нет")
    for uid, info_data in admins.items():
        username = info_data.get('username')
        name = info_data.get('full_name') or uid
        label = "@" + username if username else name
        is_super = " (суперадмин)" if info_data.get('is_super') else ""
        print(f"  {GREEN}{label}{RESET} — ID: {uid}{is_super}")

    if pending:
        print(f"\n{BOLD}Ожидают доступа:{RESET}")
        for uid, info_data in pending.items():
            username = info_data.get('username')
            name = info_data.get('full_name') or uid
            label = "@" + username if username else name
            print(f"  {YELLOW}{label}{RESET} — ID: {uid} ({info_data.get('requested_at', '')})")
    print()

def cmd_admin_add(telegram_id):
    if not Path(ADMINS_PATH).exists():
        err("Файл админов не найден — сначала запусти бота")
    with open(ADMINS_PATH) as f:
        data = json.load(f)
    uid = str(telegram_id)
    if uid in data.get('admins', {}):
        warn(f"ID {telegram_id} уже является админом")
        return
    pending = data.get('pending', {})
    if uid in pending:
        data['admins'][uid] = pending.pop(uid)
    else:
        data['admins'][uid] = {"username": None, "full_name": None}
    data['pending'] = pending
    with open(ADMINS_PATH, 'w') as f:
        json.dump(data, f, indent=2)
    ok(f"Админ {telegram_id} добавлен")

def cmd_admin_delete(telegram_id):
    if not Path(ADMINS_PATH).exists():
        err("Файл админов не найден")
    with open(ADMINS_PATH) as f:
        data = json.load(f)
    uid = str(telegram_id)
    if uid not in data.get('admins', {}):
        err(f"ID {telegram_id} не найден в списке админов")
    del data['admins'][uid]
    with open(ADMINS_PATH, 'w') as f:
        json.dump(data, f, indent=2)
    ok(f"Админ {telegram_id} удалён")

def cmd_status():
    result = subprocess.run(
        ["docker", "inspect", "--format",
         "{{.State.Status}} {{.State.StartedAt}}", "telemt"],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        err("Контейнер telemt не найден")

    status, started_at = result.stdout.strip().split(" ", 1)
    started_dt = datetime.fromisoformat(started_at[:19])
    uptime = datetime.now() - started_dt
    hours, rem = divmod(int(uptime.total_seconds()), 3600)
    minutes = rem // 60

    meta = load_meta()
    content = read_toml()
    users = get_users_from_toml(content)
    active = sum(1 for u in users.values() if not u['disabled'])
    disabled = sum(1 for u in users.values() if u['disabled'])

    print(f"\n{BOLD}=== Telemt MTProxy ==={RESET}")
    print(f"Статус:    {GREEN}running{RESET}" if status == "running" else f"Статус:    {RED}{status}{RESET}")
    print(f"Аптайм:    {hours}ч {minutes}м")
    print(f"Хост:      {PUBLIC_HOST}:{PUBLIC_PORT}")
    print(f"Юзеры:     {GREEN}{active} active{RESET} / {RED}{disabled} disabled{RESET}")
    print()

def cmd_logs(lines=50):
    subprocess.run(["docker", "logs", "--tail", str(lines), "telemt"])

def cmd_expire(days=7):
    meta = load_meta()
    content = read_toml()
    users = get_users_from_toml(content)
    soon = []
    for name, data in meta.items():
        if data.get('expires'):
            exp = datetime.strptime(data['expires'], "%Y-%m-%d")
            diff = (exp - datetime.now()).days
            if diff <= int(days):
                disabled = users.get(name, {}).get('disabled', False)
                soon.append((name, data['expires'], diff, disabled))

    if not soon:
        ok(f"Нет юзеров с истекающим сроком в ближайшие {days} дней")
        return

    print(f"\n{BOLD}Юзеры с истекающим сроком (до {days} дней):{RESET}")
    for name, expires, diff, disabled in sorted(soon, key=lambda x: x[2]):
        status = f"{RED}disabled{RESET}" if disabled else f"{GREEN}active{RESET}"
        color = RED if diff <= 3 else YELLOW
        print(f"  {color}{name}{RESET} — {expires} (через {diff} дн.) [{status}]")
    print()

def cmd_update():
    info("Обновляем Docker образ...")
    subprocess.run(["docker", "pull", "whn0thacked/telemt-docker:latest"], check=True)
    info("Перезапускаем контейнер...")
    subprocess.run(["docker", "compose", "up", "-d"], cwd=TELEMT_DIR, check=True)
    ok("Обновление завершено!")

def cmd_backup():
    import tarfile
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    backup_file = os.path.expanduser(f"~/telmgr-backup-{timestamp}.tar.gz")
    files = [
        os.path.join(TELEMT_DIR, "telemt.toml"),
        os.path.join(TELEMT_DIR, ".telmgr-meta.json"),
        os.path.join(TELEMT_DIR, ".telmgr-admins.json"),
        os.path.join(TELEMT_DIR, ".env"),
    ]
    with tarfile.open(backup_file, "w:gz") as tar:
        for f in files:
            if os.path.exists(f):
                tar.add(f, arcname=os.path.basename(f))
    ok(f"Бэкап создан: {backup_file}")
    if PUBLIC_HOST:
        warn(f"При восстановлении на новом сервере домен должен быть идентичным: {PUBLIC_HOST}")
    else:
        warn("При восстановлении на новом сервере домен должен совпадать с оригинальным!")
    warn("Иначе ссылки пользователей перестанут работать!")

def cmd_restore(backup_file):
    import tarfile
    if not os.path.exists(backup_file):
        err(f"Файл не найден: {backup_file}")
    warn(f"Восстановление из {backup_file}")
    warn(f"Убедись что домен сервера совпадает с оригинальным!")
    confirm = input("Продолжить? [y/N]: ")
    if confirm.lower() != 'y':
        info("Отменено")
        return
    with tarfile.open(backup_file, "r:gz") as tar:
        tar.extractall(TELEMT_DIR)
    ok("Файлы восстановлены")
    info("Перезапусти контейнер: docker compose restart")
    info("Перезапусти бота: systemctl restart telmgr-bot")

def usage():
    print(f"""
{BOLD}telmgr — менеджер пользователей Telemt MTProxy{RESET}

Использование:
  telmgr user add <name> [days]     Добавить пользователя (days=0 — бессрочно)
  telmgr user delete <name>         Удалить пользователя
  telmgr user disable <name>        Отключить пользователя
  telmgr user enable <name>         Включить пользователя
  telmgr user limit <name> <days>   Установить лимит (0 — снять)
  telmgr user list                  Список пользователей
  telmgr user link <name>           Показать ссылку
  telmgr user import <name>         Импортировать существующего юзера из конфига
  telmgr user expire [days]         Юзеры с истекающим сроком (default: 7 дней)

  telmgr admin list                 Список админов
  telmgr admin add <telegram_id>    Добавить админа
  telmgr admin delete <telegram_id> Удалить админа

  telmgr status                     Статус прокси
  telmgr logs [lines]               Логи контейнера (default: 50)
  telmgr update                     Обновить Docker образ
  telmgr backup                     Создать бэкап
  telmgr restore <file>             Восстановить из бэкапа
""")

def main():
    args = sys.argv[1:]
    if len(args) < 1:
        usage()
        sys.exit(0)

    section = args[0]

    # Команды без подкоманд
    if section == "status":
        cmd_status()
        return
    elif section == "logs":
        lines = args[1] if len(args) > 1 else 50
        cmd_logs(lines)
        return
    elif section == "update":
        cmd_update()
        return
    elif section == "backup":
        cmd_backup()
        return
    elif section == "restore":
        if len(args) < 2: err("Укажи путь к файлу бэкапа")
        cmd_restore(args[1])
        return

    if len(args) < 2:
        usage()
        sys.exit(0)

    cmd = args[1]

    if section == "user":
        if cmd == "add":
            if len(args) < 3: err("Укажи имя пользователя")
            days = args[3] if len(args) > 3 else 0
            cmd_add(args[2], days)
        elif cmd == "delete":
            if len(args) < 3: err("Укажи имя пользователя")
            cmd_delete(args[2])
        elif cmd == "disable":
            if len(args) < 3: err("Укажи имя пользователя")
            cmd_disable(args[2])
        elif cmd == "enable":
            if len(args) < 3: err("Укажи имя пользователя")
            cmd_enable(args[2])
        elif cmd == "limit":
            if len(args) < 4: err("Укажи имя и количество дней")
            cmd_limit(args[2], args[3])
        elif cmd == "list":
            cmd_list()
        elif cmd == "link":
            if len(args) < 3: err("Укажи имя пользователя")
            cmd_link(args[2])
        elif cmd == "import":
            if len(args) < 3: err("Укажи имя пользователя")
            cmd_import(args[2])
        elif cmd == "expire":
            days = args[2] if len(args) > 2 else 7
            cmd_expire(days)
        else:
            err(f"Неизвестная команда: {cmd}")
    elif section == "admin":
        if cmd == "list":
            cmd_admin_list()
        elif cmd == "add":
            if len(args) < 3: err("Укажи Telegram ID")
            cmd_admin_add(args[2])
        elif cmd == "delete":
            if len(args) < 3: err("Укажи Telegram ID")
            cmd_admin_delete(args[2])
        else:
            err(f"Неизвестная команда: {cmd}")
    else:
        usage()
        sys.exit(0)

if __name__ == "__main__":
    main()
