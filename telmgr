def load_servers():
    if not Path(SERVERS_PATH).exists():
        return {"servers": {"local": {
            "name": "Local",
            "url": "local",
            "api_key": None,
            "host": PUBLIC_HOST or "",
            "port": PUBLIC_PORT
        }}}
    with open(SERVERS_PATH) as f:
        return json.load(f)

def save_servers(data):
    with open(SERVERS_PATH, "w") as f:
        json.dump(data, f, indent=2)

def resolve_server_id(id_or_name):
    """Возвращает ID сервера по ID или имени (case-insensitive). Падает с err() если не найден."""
    data = load_servers()
    servers = data.get("servers", {})
    if id_or_name in servers:
        return id_or_name
    needle = id_or_name.lower()
    for sid, s in servers.items():
        if s.get("name", "").lower() == needle:
            return sid
    err(f"Сервер '{id_or_name}' не найден")

def cmd_server_list():
    data = load_servers()
