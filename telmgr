GITHUB_RAW = "https://raw.githubusercontent.com/Sketso/telmgr/master"
TELMGR_BIN = "/usr/local/bin/telmgr"

def cmd_uninstall():
    import urllib.request, tempfile, stat
    if os.geteuid() != 0:
        err("Запусти от root")
    url = f"{GITHUB_RAW}/scripts/uninstall.sh"
    with tempfile.NamedTemporaryFile(suffix=".sh", delete=False) as tmp:
        tmp_path = tmp.name
    try:
        urllib.request.urlretrieve(url, tmp_path)
        os.chmod(tmp_path, os.stat(tmp_path).st_mode | stat.S_IEXEC)
        subprocess.run(["bash", tmp_path], check=False)
    finally:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass

def cmd_update():
    import urllib.request, shutil, tempfile, stat

    if os.geteuid() != 0:
        err("Run as root" if not _is_russian() else "Запусти от root")

    ru = _is_russian()
    info("Updating telmgr..." if not ru else "Обновляем telmgr...")
    with tempfile.NamedTemporaryFile(delete=False) as tmp:
        with urllib.request.urlopen(f"{GITHUB_RAW}/telmgr") as resp:
            tmp.write(resp.read())
        tmp_path = tmp.name
    os.chmod(tmp_path, os.stat(tmp_path).st_mode | stat.S_IEXEC | stat.S_IXGRP | stat.S_IXOTH)
    shutil.move(tmp_path, TELMGR_BIN)
    shutil.copy(TELMGR_BIN, TELMGR_BIN + ".py")
    ok("telmgr updated" if not ru else "telmgr обновлён")

    bot_path = os.path.join(TELEMT_DIR, "bot.py")
    if os.path.exists(bot_path):
        info("Updating bot.py..." if not ru else "Обновляем bot.py...")
        with urllib.request.urlopen(f"{GITHUB_RAW}/bot/bot.py") as resp:
            content = resp.read()
        with open(bot_path, "wb") as f:
            f.write(content)
        ok("bot.py updated" if not ru else "bot.py обновлён")
