from pathlib import Path

# === Конфиг ===
from dotenv import load_dotenv

# Ищем .env в стандартных местах
_env_paths = [
    os.path.join(os.path.expanduser("~"), "telemt", ".env"),
    "/root/telemt/.env",
    ".env"
]
for _p in _env_paths:
