def main():
    args = sys.argv[1:]
    if len(args) < 1:
        usage()
        sys.exit(0)

    section = args[0]

    # Команды без подкоманд
    if section == "status":
        cmd_status()
        return
    elif section == "logs":
        lines = args[1] if len(args) > 1 else 50
        cmd_logs(lines)
        return
    elif section == "update":
        cmd_update()
        return
    elif section == "coreupdate":
        cmd_coreupdate()
        return
    elif section == "backup":
        if len(args) > 1 and args[1] == "auto":
            sub = args[2] if len(args) > 2 else "status"
            if sub == "enable":
                hour = int(args[3]) if len(args) > 3 else 3
                cmd_backup_auto_enable(hour)
            elif sub == "disable":
                cmd_backup_auto_disable()
            else:
                cmd_backup_auto_status()
        else:
            cmd_backup()
        return
    elif section == "restore":
        if len(args) < 2: err("Укажи путь к файлу бэкапа")
        cmd_restore(args[1])
        return
    elif section == "restart":
        cmd_restart()
        return
    elif section == "serve":
        cmd_serve()
        return
    elif section == "uninstall":
        cmd_uninstall()
        return

    if len(args) < 2:
        usage()
        sys.exit(0)

    cmd = args[1]

    if section == "user":
        if cmd == "add":
            if len(args) < 3: err("Укажи имя пользователя")
            days = args[3] if len(args) > 3 else 0
            cmd_add(args[2], days)
        elif cmd == "delete":
            if len(args) < 3: err("Укажи имя пользователя")
            cmd_delete(args[2])
        elif cmd == "disable":
            if len(args) < 3: err("Укажи имя пользователя")
            cmd_disable(args[2])
        elif cmd == "enable":
            if len(args) < 3: err("Укажи имя пользователя")
            cmd_enable(args[2])
        elif cmd == "limit":
            if len(args) < 4: err("Укажи имя и количество дней")
            cmd_limit(args[2], args[3])
        elif cmd == "list":
            cmd_list()
        elif cmd == "link":
            if len(args) < 3: err("Укажи имя пользователя")
            cmd_link(args[2])
        elif cmd == "import":
            if len(args) < 3: err("Укажи имя пользователя")
            cmd_import(args[2])
        elif cmd == "expire":
            days = args[2] if len(args) > 2 else 7
            cmd_expire(days)
        elif cmd == "stats":
            cmd_stats()
        else:
            err(f"Неизвестная команда: {cmd}")
    elif section == "admin":
        if cmd == "list":
            cmd_admin_list()
        elif cmd == "add":
            if len(args) < 3: err("Укажи Telegram ID")
            cmd_admin_add(args[2])
        elif cmd == "delete":
            if len(args) < 3: err("Укажи Telegram ID")
            cmd_admin_delete(args[2])
        else:
            err(f"Неизвестная команда: {cmd}")
    elif section == "bot":
        if cmd == "setup":
            cmd_bot_setup()
        elif cmd == "restart":
            cmd_bot_restart()
        elif cmd == "logs":
            lines = int(args[2]) if len(args) > 2 else 50
            cmd_bot_logs(lines)
        else:
            err(f"Неизвестная команда: {cmd}")
    elif section == "server":
        if cmd == "list":
            cmd_server_list()
        elif cmd == "add":
            if len(args) < 5: err("Укажи: server add <name> <url> <api_key>")
            cmd_server_add(args[2], args[3], args[4])
        elif cmd == "remove":
            if len(args) < 3: err("Укажи ID сервера")
            cmd_server_remove(args[2])
        elif cmd == "rename":
            if len(args) < 4: err("Укажи: server rename <id> <новое_имя>")
            cmd_server_rename(args[2], args[3])
        elif cmd == "test":
            if len(args) < 3: err("Укажи ID сервера")
            cmd_server_test(args[2])
        else:
            err(f"Неизвестная команда: {cmd}")
    else:
        usage()
        sys.exit(0)

if __name__ == "__main__":
    main()
