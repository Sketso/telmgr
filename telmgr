def cmd_admin_list():
    if not Path(ADMINS_PATH).exists():
        info("Файл админов не найден")
        return
    with open(ADMINS_PATH) as f:
        data = json.load(f)
    admins = data.get('admins', {})
    pending = data.get('pending', {})
    print(f"\n{BOLD}Админы:{RESET}")

    if not admins:
        print("  нет")
    for uid, info_data in admins.items():
        username = info_data.get('username')
        name = info_data.get('full_name') or uid
        label = "@" + username if username else name
        is_super = " (суперадмин)" if info_data.get('is_super') else ""
        print(f"  {GREEN}{label}{RESET} — ID: {uid}{is_super}")

    if pending:
        print(f"\n{BOLD}Ожидают доступа:{RESET}")
        for uid, info_data in pending.items():
            username = info_data.get('username')
            name = info_data.get('full_name') or uid
            label = "@" + username if username else name
            print(f"  {YELLOW}{label}{RESET} — ID: {uid} ({info_data.get('requested_at', '')})")
    print()

def cmd_admin_add(telegram_id):
    if not Path(ADMINS_PATH).exists():
        err("Файл админов не найден — сначала запусти бота")
    with open(ADMINS_PATH) as f:
        data = json.load(f)
    uid = str(telegram_id)
    if uid in data.get('admins', {}):
        warn(f"ID {telegram_id} уже является админом")
        return
    pending = data.get('pending', {})
    if uid in pending:
        data['admins'][uid] = pending.pop(uid)
    else:
        data['admins'][uid] = {"username": None, "full_name": None}
    data['pending'] = pending
    with open(ADMINS_PATH, 'w') as f:
        json.dump(data, f, indent=2)
    ok(f"Админ {telegram_id} добавлен")

def cmd_admin_delete(telegram_id):
    if not Path(ADMINS_PATH).exists():
        err("Файл админов не найден")
    with open(ADMINS_PATH) as f:
        data = json.load(f)
    uid = str(telegram_id)
    if uid not in data.get('admins', {}):
        err(f"ID {telegram_id} не найден в списке админов")
    del data['admins'][uid]
    with open(ADMINS_PATH, 'w') as f:
        json.dump(data, f, indent=2)
    ok(f"Админ {telegram_id} удалён")

def cmd_status():
    result = subprocess.run(
        ["docker", "inspect", "--format",
         "{{.State.Status}} {{.State.StartedAt}}", "telemt"],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        err("Контейнер telemt не найден")

    status, started_at = result.stdout.strip().split(" ", 1)
    started_dt = datetime.fromisoformat(started_at[:19])
    uptime = datetime.now() - started_dt
    hours, rem = divmod(int(uptime.total_seconds()), 3600)
    minutes = rem // 60

    meta = load_meta()
    content = read_toml()
    users = get_users_from_toml(content)
    active = sum(1 for u in users.values() if not u['disabled'])
    disabled = sum(1 for u in users.values() if u['disabled'])

    print(f"\n{BOLD}=== Telemt MTProxy ==={RESET}")
    print(f"Статус:    {GREEN}running{RESET}" if status == "running" else f"Статус:    {RED}{status}{RESET}")
    print(f"Аптайм:    {hours}ч {minutes}м")
    print(f"Хост:      {PUBLIC_HOST}:{PUBLIC_PORT}")
    print(f"Юзеры:     {GREEN}{active} active{RESET} / {RED}{disabled} disabled{RESET}")

    bot_result = subprocess.run(
        ["docker", "inspect", "--format",
         "{{.State.Status}} {{.State.StartedAt}}", "telmgr-bot"],
        capture_output=True, text=True
    )
    if bot_result.returncode == 0:
        bot_status, bot_started_at = bot_result.stdout.strip().split(" ", 1)
        bot_started_dt = datetime.fromisoformat(bot_started_at[:19])
        bot_uptime = datetime.now() - bot_started_dt
        bot_hours, bot_rem = divmod(int(bot_uptime.total_seconds()), 3600)
        bot_minutes = bot_rem // 60

        admins_count = 0
        if os.path.exists(ADMINS_PATH):
            try:
                with open(ADMINS_PATH) as f:
                    admins_data = json.load(f)
                admins_count = len(admins_data.get("admins", {}))
            except Exception:
                pass

        print(f"\n{BOLD}=== Telegram Bot ==={RESET}")
        print(f"Статус:    {GREEN}running{RESET}" if bot_status == "running" else f"Статус:    {RED}{bot_status}{RESET}")
        print(f"Аптайм:    {bot_hours}ч {bot_minutes}м")
        print(f"Админов:   {admins_count}")
    print()

