    print(f"\n{BOLD}{'ID':<10} {'Название':<20} {'URL':<35} {'Хост':<25} {'Порт'}{RESET}")
    print("─" * 95)
    for sid, s in servers.items():
        url = s.get("url", "")
        display_url = "(local)" if url == "local" else url
        print(f"{sid:<10} {s.get('name',''):<20} {display_url:<35} {s.get('host',''):<25} {s.get('port','')}")
    print()

def cmd_server_add(name, url, api_key):
    import urllib.request, urllib.error
    if not url.startswith("http://") and not url.startswith("https://"):
        err("URL должен начинаться с http:// или https://")
    data = load_servers()
    req = urllib.request.Request(url.rstrip("/") + "/status")
    req.add_header("Authorization", f"Bearer {api_key}")
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            status_data = json.loads(resp.read())
        host = status_data.get("host", "")
        port = str(status_data.get("port", ""))
        ok(f"Сервер доступен: {host}:{port}")
    except Exception as e:
        warn(f"Не удалось подключиться: {e}")
        host, port = "", ""
    sid = subprocess.check_output(["openssl", "rand", "-hex", "4"]).decode().strip()
    data["servers"][sid] = {"name": name, "url": url, "api_key": api_key, "host": host, "port": port}
    save_servers(data)
    ok(f"Сервер '{name}' добавлен (ID: {sid})")

def cmd_server_remove(sid):
    sid = resolve_server_id(sid)
    if sid == "local":
        err("Нельзя удалить локальный сервер")
    data = load_servers()
    name = data["servers"][sid].get("name", sid)
    del data["servers"][sid]
    save_servers(data)
    ok(f"Сервер '{name}' удалён")

def cmd_server_rename(sid, new_name):
