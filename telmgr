# === HTTP API сервер (slave mode) ===
class TelmgrAPIHandler:
    def __init__(self):
        pass

import http.server, socketserver, io, contextlib

class _TelmgrAPIHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        pass

    def _check_auth(self):
        auth = self.headers.get("Authorization", "")
        if not API_KEY or auth != f"Bearer {API_KEY}":
            self._send_json({"error": "Unauthorized"}, 401)
            return False
        return True

    def _send_json(self, data, status=200):
        body = json.dumps(data).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", len(body))
        self.end_headers()
        self.wfile.write(body)

    def _read_body(self):
        length = int(self.headers.get("Content-Length", 0))
        return json.loads(self.rfile.read(length)) if length else {}

    def _call_cmd(self, fn, *args):
        buf = io.StringIO()
        try:
            with contextlib.redirect_stdout(buf):
                fn(*args)
            return buf.getvalue(), None
        except SystemExit as e:
            return buf.getvalue(), str(e)
        except Exception as e:
            return "", str(e)

    def _parse_path(self):
        path = self.path.split("?")[0].rstrip("/")
        parts = [p for p in path.split("/") if p]
        return parts

    def do_GET(self):
        if not self._check_auth():
            return
        parts = self._parse_path()
        if parts == ["status"]:
            self._handle_status()
        elif parts == ["users"]:
            self._handle_get_users()
        elif len(parts) == 3 and parts[0] == "users" and parts[2] == "link":
            self._handle_get_link(parts[1])
        else:
            self._send_json({"error": "Not found"}, 404)

    def do_POST(self):
        if not self._check_auth():
            return
        parts = self._parse_path()
        if parts == ["users"]:
            self._handle_add_user()
        elif len(parts) == 3 and parts[0] == "users" and parts[2] == "enable":
            _, e = self._call_cmd(cmd_enable, parts[1])
            self._send_json({"error": e} if e else {"ok": True})
        elif len(parts) == 3 and parts[0] == "users" and parts[2] == "disable":
            _, e = self._call_cmd(cmd_disable, parts[1])
            self._send_json({"error": e} if e else {"ok": True})
        elif len(parts) == 3 and parts[0] == "users" and parts[2] == "limit":
            body = self._read_body()
            _, e = self._call_cmd(cmd_limit, parts[1], body.get("days", 0))
            self._send_json({"error": e} if e else {"ok": True})
        else:
            self._send_json({"error": "Not found"}, 404)

    def do_DELETE(self):
        if not self._check_auth():
            return
        parts = self._parse_path()
        if len(parts) == 2 and parts[0] == "users":
            _, e = self._call_cmd(cmd_delete, parts[1])
            self._send_json({"error": e} if e else {"ok": True})
        else:
            self._send_json({"error": "Not found"}, 404)

    def _handle_status(self):
        proxy_status = "unknown"
        uptime_seconds = 0
        try:
            result = subprocess.run(
                ["docker", "inspect", "--format", "{{.State.Status}} {{.State.StartedAt}}", "telemt"],
                capture_output=True, text=True
            )
            if result.returncode == 0:
                parts = result.stdout.strip().split(" ", 1)
                proxy_status = parts[0]
                if len(parts) > 1:
                    try:
                        started_dt = datetime.fromisoformat(parts[1][:19])
                        uptime_seconds = int((datetime.now() - started_dt).total_seconds())
                    except Exception:
                        pass
        except FileNotFoundError:
            proxy_status = "running"
        content = read_toml()
        users = get_users_from_toml(content)
        active = sum(1 for u in users.values() if not u['disabled'])
        disabled = sum(1 for u in users.values() if u['disabled'])
        self._send_json({
            "proxy_status": proxy_status,
            "uptime_seconds": uptime_seconds,
            "host": PUBLIC_HOST or "",
            "port": PUBLIC_PORT,
            "users_active": active,
            "users_disabled": disabled
        })

    def _handle_get_users(self):
        content = read_toml()
        toml_users = get_users_from_toml(content)
        meta = load_meta()
        result = {}
        for name, tdata in toml_users.items():
            m = meta.get(name, {})
            result[name] = {
                "secret": tdata["secret"],
                "disabled": tdata["disabled"],
                "created": m.get("created"),
                "expires": m.get("expires"),
                "admin_id": m.get("admin_id"),
                "admin_name": m.get("admin_name"),
                "admin_username": m.get("admin_username"),
            }
        self._send_json(result)

    def _handle_add_user(self):
        body = self._read_body()
        name = body.get("name", "")
        days = body.get("days", 0)
        admin_id = body.get("admin_id")
        admin_name = body.get("admin_name")
        admin_username = body.get("admin_username")
        if not re.match(r'^[a-zA-Z0-9_]+$', name):
            self._send_json({"error": "Недопустимое имя пользователя"}, 400)
            return
        content = read_toml()
        users = get_users_from_toml(content)
        if name in users:
            self._send_json({"error": f"Пользователь '{name}' уже существует"}, 409)
            return
        secret = generate_secret()
        lines = content.splitlines()
        result_lines = []
        inserted = False
        for line in lines:
            result_lines.append(line)
            if line.strip() == "[access.users]" and not inserted:
                result_lines.append(f'{name} = "{secret}"')
                inserted = True
        if not inserted:
            self._send_json({"error": "Секция [access.users] не найдена"}, 500)
            return
        write_toml("\n".join(result_lines))
        meta = load_meta()
        expires = None
        if days and int(days) > 0:
            expires = (datetime.now() + timedelta(days=int(days))).strftime("%Y-%m-%d")
        meta[name] = {
            "secret": secret,
            "created": datetime.now().strftime("%Y-%m-%d"),
            "expires": expires,
            "disabled": False,
            "admin_id": admin_id,
            "admin_name": admin_name,
            "admin_username": admin_username,
        }
        save_meta(meta)
        if expires:
            add_cron(name, expires)
        self._send_json({"link": build_link(secret), "expires": expires})

    def _handle_get_link(self, name):
        content = read_toml()
        users = get_users_from_toml(content)
        if name not in users:
            self._send_json({"error": f"Пользователь '{name}' не найден"}, 404)
            return
        self._send_json({"link": build_link(users[name]["secret"])})


def cmd_serve():
    if not API_KEY:
        err("TELMGR_API_KEY не установлен в .env")
    class ThreadedTCPServer(socketserver.ThreadingMixIn, socketserver.TCPServer):
        allow_reuse_address = True
    with ThreadedTCPServer(("0.0.0.0", API_PORT), _TelmgrAPIHandler) as server:
        info(f"telmgr API сервер запущен на порту {API_PORT}")
        server.serve_forever()


